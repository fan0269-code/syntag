generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========== 核心实体 ==========

model Discipline {
  id          String   @id @default(uuid())
  slug        String   @unique
  titleEn     String   @map("title_en")
  titleZh     String?  @map("title_zh")
  descriptionEn String? @map("description_en")
  descriptionZh String? @map("description_zh")
  overviewEn  String?  @map("overview_en")
  overviewZh  String?  @map("overview_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  status      String   @default("draft") // draft | published | archived
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  fields      Field[]
  theories    DisciplineTheory[]

  @@map("disciplines")
}

model Field {
  id          String   @id @default(uuid())
  slug        String   @unique
  titleEn     String   @map("title_en")
  titleZh     String?  @map("title_zh")
  descriptionEn String? @map("description_en")
  descriptionZh String? @map("description_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  status      String   @default("draft")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  disciplineId String     @map("discipline_id")
  discipline   Discipline @relation(fields: [disciplineId], references: [id])
  theories     FieldTheory[]

  @@map("fields")
}

model Theory {
  id           String   @id @default(uuid())
  slug         String   @unique
  titleEn      String   @map("title_en")
  titleZh      String?  @map("title_zh")
  subtitleEn   String?  @map("subtitle_en")
  subtitleZh   String?  @map("subtitle_zh")
  summaryEn    String?  @map("summary_en")
  summaryZh    String?  @map("summary_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  depth        String   @default("D1") // D1 | D2 | D3
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")
  searchVectorEn Unsupported("tsvector")? @default(dbgenerated("((setweight(to_tsvector('english'::regconfig, COALESCE(title_en, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(summary_en, ''::text)), 'B'::\"char\")) || setweight(to_tsvector('english'::regconfig, COALESCE((content_jsonb)::text, ''::text)), 'C'::\"char\"))")) @map("search_vector_en")

  // 理论谱系（有向边）
  sourceRelations TheoryGenealogy[] @relation("SourceTheory")
  targetRelations TheoryGenealogy[] @relation("TargetTheory")
  // 关联
  scholars        TheoryScholar[]
  works           TheoryWork[]
  concepts        TheoryConcept[]
  fields          FieldTheory[]
  topics          TopicTheory[]
  disciplines     DisciplineTheory[]

  @@index([searchVectorEn], map: "theories_search_idx", type: Gin)
  @@map("theories")
}

// ========== 理论谱系（核心表） ==========

model TheoryGenealogy {
  id              String   @id @default(uuid())
  sourceTheoryId  String   @map("source_theory_id")
  targetTheoryId  String   @map("target_theory_id")
  relationType    String   @map("relation_type") // precursor_of | branched_from | extended_by | critiqued_by | integrated_with
  descriptionEn   String   @map("description_en")
  descriptionZh   String?  @map("description_zh")
  strength        Int      @default(3) // 1-5
  keyScholarId    String?  @map("key_scholar_id")
  keyWorkId       String?  @map("key_work_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  sourceTheory Theory  @relation("SourceTheory", fields: [sourceTheoryId], references: [id])
  targetTheory Theory  @relation("TargetTheory", fields: [targetTheoryId], references: [id])
  keyScholar   Scholar? @relation(fields: [keyScholarId], references: [id])
  keyWork      Work?    @relation(fields: [keyWorkId], references: [id])

  @@map("theory_genealogy")
}

// ========== 学者 ==========

model Scholar {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  titleEn      String?  @map("title_en")
  titleZh      String?  @map("title_zh")
  bioEn        String?  @map("bio_en")
  bioZh        String?  @map("bio_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  photoUrl     String?  @map("photo_url")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")
  searchVectorEn Unsupported("tsvector")? @default(dbgenerated("(((setweight(to_tsvector('english'::regconfig, COALESCE(name, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(title_en, ''::text)), 'A'::\"char\")) || setweight(to_tsvector('english'::regconfig, COALESCE(bio_en, ''::text)), 'B'::\"char\")) || setweight(to_tsvector('english'::regconfig, COALESCE((content_jsonb)::text, ''::text)), 'C'::\"char\"))")) @map("search_vector_en")

  theories           TheoryScholar[]
  genealogyRelations TheoryGenealogy[]
  sourceRelations    ScholarScholar[] @relation("SourceScholar")
  targetRelations    ScholarScholar[] @relation("TargetScholar")

  @@index([searchVectorEn], map: "scholars_search_idx", type: Gin)
  @@map("scholars")
}

model ScholarScholar {
  sourceScholarId String  @map("source_scholar_id")
  targetScholarId String  @map("target_scholar_id")
  relationship    String  // influenced_by | student_of | collaborator_of | critic_of | contemporary_of
  descriptionEn   String? @map("description_en")
  descriptionZh   String? @map("description_zh")

  sourceScholar Scholar @relation("SourceScholar", fields: [sourceScholarId], references: [id])
  targetScholar Scholar @relation("TargetScholar", fields: [targetScholarId], references: [id])

  @@id([sourceScholarId, targetScholarId])
  @@map("scholar_scholar")
}

// ========== 原典 ==========

model Work {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  titleZh      String?  @map("title_zh")
  authors      Json     @default("[]") // [{name, role}]
  year         Int?
  publisher    String?
  doi          String?
  isbn         String?
  contentJsonb Json     @default("{}") @map("content_jsonb")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")
  searchVectorEn Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(title, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE((content_jsonb)::text, ''::text)), 'C'::\"char\"))")) @map("search_vector_en")

  theories           TheoryWork[]
  genealogyRelations TheoryGenealogy[]

  @@index([searchVectorEn], map: "works_search_idx", type: Gin)
  @@map("works")
}

// ========== 概念 ==========

model Concept {
  id           String   @id @default(uuid())
  slug         String   @unique
  termEn       String   @map("term_en")
  termZh       String?  @map("term_zh")
  definitionEn String?  @map("definition_en")
  definitionZh String?  @map("definition_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")

  theories TheoryConcept[]

  @@map("concepts")
}

// ========== 研究主题 ==========

model Topic {
  id           String   @id @default(uuid())
  slug         String   @unique
  questionEn   String   @map("question_en")
  questionZh   String?  @map("question_zh")
  contentJsonb Json     @default("{}") @map("content_jsonb")
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")
  searchVectorEn Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(question_en, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE((content_jsonb)::text, ''::text)), 'C'::\"char\"))")) @map("search_vector_en")

  theories TopicTheory[]

  @@index([searchVectorEn], map: "topics_search_idx", type: Gin)
  @@map("topics")
}

// ========== 框架模板 ==========

model Framework {
  id            String   @id @default(uuid())
  slug          String   @unique
  titleEn       String   @map("title_en")
  titleZh       String?  @map("title_zh")
  descriptionEn String?  @map("description_en")
  descriptionZh String?  @map("description_zh")
  contentJsonb  Json     @default("{}") @map("content_jsonb")
  status        String   @default("draft")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  publishedAt   DateTime? @map("published_at")

  @@map("frameworks")
}

// ========== 关联表（多对多） ==========

model DisciplineTheory {
  disciplineId String @map("discipline_id")
  theoryId     String @map("theory_id")
  relevance    String @default("primary") // primary | secondary

  discipline Discipline @relation(fields: [disciplineId], references: [id])
  theory     Theory     @relation(fields: [theoryId], references: [id])

  @@id([disciplineId, theoryId])
  @@map("discipline_theory")
}

model FieldTheory {
  fieldId   String @map("field_id")
  theoryId  String @map("theory_id")
  relevance String @default("primary")

  field  Field  @relation(fields: [fieldId], references: [id])
  theory Theory @relation(fields: [theoryId], references: [id])

  @@id([fieldId, theoryId])
  @@map("field_theory")
}

model TheoryScholar {
  theoryId  String @map("theory_id")
  scholarId String @map("scholar_id")
  role      String // founder | key_contributor | extender | critic | synthesizer

  theory  Theory  @relation(fields: [theoryId], references: [id])
  scholar Scholar @relation(fields: [scholarId], references: [id])

  @@id([theoryId, scholarId])
  @@map("theory_scholar")
}

model TheoryWork {
  theoryId     String @map("theory_id")
  workId       String @map("work_id")
  relationship String // founding_text | major_development | critique | synthesis | core_work | core_concept_source | tradition_source | adjacent_theory_source | institutional_context_source | normative_resource

  theory Theory @relation(fields: [theoryId], references: [id])
  work   Work   @relation(fields: [workId], references: [id])

  @@id([theoryId, workId])
  @@map("theory_work")
}

model TheoryConcept {
  theoryId   String @map("theory_id")
  conceptId  String @map("concept_id")
  importance String @default("core") // core | peripheral

  theory  Theory  @relation(fields: [theoryId], references: [id])
  concept Concept @relation(fields: [conceptId], references: [id])

  @@id([theoryId, conceptId])
  @@map("theory_concept")
}

model TopicTheory {
  topicId          String  @map("topic_id")
  theoryId         String  @map("theory_id")
  suitability      String  // high | medium | low
  suitabilityNotesEn String? @map("suitability_notes_en")
  suitabilityNotesZh String? @map("suitability_notes_zh")
  riskNotesEn      String? @map("risk_notes_en")
  riskNotesZh      String? @map("risk_notes_zh")
  recommendation   String? // primary | supporting | not_recommended

  topic  Topic  @relation(fields: [topicId], references: [id])
  theory Theory @relation(fields: [theoryId], references: [id])

  @@id([topicId, theoryId])
  @@map("topic_theory")
}

// ========== 核验追踪 ==========

model Verification {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type") // theory | scholar | work | concept | topic
  entityId   String   @map("entity_id")
  fieldPath  String   @map("field_path") // content_jsonb.en.origins
  level      String   // L1_verified | L2_reviewed | L3_pending
  sources    Json     @default("[]")
  notes      String?
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, entityId, fieldPath])
  @@map("verifications")
}
